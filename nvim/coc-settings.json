{
    "languageserver": {
        "clojure-lsp": {
            "command": "bash",
            "args": ["-c", "clojure-lsp"],
            "filetypes": ["clojure"],
            "rootPatterns": ["project.clj"],
            "additionalSchemes": ["jar", "zipfile"],
            "trace.server": "verbose",
            "initializationOptions": {
                "project-specs": [{
                    "project-path": "deps.edn",
                    "classpath-cmd": ["clj", "-Spath"]}]
            }
        },
        "golang": {
            "command": "gopls",
            "args": [],
            "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
            "filetypes": ["go"]
        },
        "bash": {
            "command": "bash-language-server",
            "args": ["start"],
            "filetypes": ["sh"],
            "ignoredRootPaths": ["~"]
        },
        "phpactor": {
            "trace.server": "verbose",
            "command": "~/nvim/plugged/phpactor/bin/phpactor",
            "args": ["language-server"],
            "filetypes": ["php","cucumber"],
            "initializationOptions": {
            },
            "settings": {
            }
        }
    },
    "snippets.ultisnips.directories": [
        "UltiSnips",
        "gosnippets/UltiSnips"
    ],
    "snippets.userSnippetsDirectory": "$VIMCONFIG/ultisnips",
    "diagnostic.enable": true,
    "coc.preferences.formatOnSaveFiletypes": ["go", "clojure", "php"],
    "coc.preferences.hoverTarget": "float",

    "diagnostic.errorSign"  : "ﮊ",
    "diagnostic.warningSign": "",
    "diagnostic.infoSign"   : "",
    "diagnostic.hintSign"   : "ﯦ",
    "suggest.snippetIndicator": "",
    "suggest.echodocSupport": true,
    "suggest.maxCompleteItemCount": 20,
    "prettier.singleQuote": true,
    "prettier.semi": false,
    "eslint.autoFixOnSave": true,
    "eslint.filetypes": ["javascript", "typescript", "typescriptreact", "javascriptreact", 
        "typescript.tsx", "vue" ],
    "vetur.validation.template": false,
        "typescript.tsx"],
    "html.format.enable": true
}
